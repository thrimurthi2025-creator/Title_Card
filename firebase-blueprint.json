{
  "entities": {
    "MovieEntry": {
      "title": "Movie Entry",
      "description": "A record of a movie's title card appearance",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Movie title" },
        "titleCardTime": { "type": "string", "description": "Timestamp when the title card appears (e.g., 00:15:30)" },
        "image": { "type": "string", "description": "Base64 encoded image or URL of the title card" },
        "authorId": { "type": "string", "description": "UID of the user who posted" },
        "authorName": { "type": "string", "description": "Name of the user who posted" },
        "isFeatured": { "type": "boolean", "description": "Whether this movie is featured on the home screen" },
        "genre": { "type": "string", "description": "Movie genre" },
        "rating": { "type": "number", "description": "Movie rating out of 10" },
        "description": { "type": "string", "description": "Movie description" },
        "posterUrl": { "type": "string", "description": "URL to the movie poster" },
        "backdropUrl": { "type": "string", "description": "URL to the movie backdrop" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "titleCardTime", "authorId", "authorName", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "name": { "type": "string", "description": "User name" },
        "email": { "type": "string", "description": "User email" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "bio": { "type": "string", "description": "User bio" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a movie",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "Comment text" },
        "userId": { "type": "string", "description": "User UID" },
        "userName": { "type": "string", "description": "User name" },
        "userPhoto": { "type": "string", "description": "User photo URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "userId", "userName", "createdAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A rating for a movie",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User UID" },
        "movieId": { "type": "string", "description": "Movie ID" },
        "rating": { "type": "number", "description": "Rating (1-5)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "movieId", "rating", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A user's post about a movie experience.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    }
  },
  "firestore": {
    "/movies/{movieId}": {
      "schema": { "$ref": "#/entities/MovieEntry" },
      "description": "Collection of movie title card entries"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/movies/{movieId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on movies"
    },
    "/ratings/{userId_movieId}": {
      "schema": { "$ref": "#/entities/Rating" },
      "description": "Movie ratings"
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "User posts"
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Follow relationships"
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Post likes"
    }
  }
}
