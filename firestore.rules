rules_version = '2';
service cloud.firestore {
  match /databases/ai-studio-14298393-ee7e-4af3-8d22-2f920195856c/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'akdiljith7@gmail.com' ||
              request.auth.uid == 'kkBfscUXJuZcSc0Yl0xLRMth1Ex1');
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function validOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    // Domain Validators
    function isValidMovieEntry() {
      let data = request.resource.data;
      return hasRequiredFields(['title', 'titleCardTime', 'authorId', 'authorName']) &&
             validStringLength('title', 1, 200) &&
             validStringLength('titleCardTime', 1, 50) &&
             validStringLength('authorName', 1, 100) &&
             (data.authorId == request.auth.uid || isAdmin()) &&
             (!( 'image' in data) || data.image == null || (data.image is string && data.image.size() <= 2097152)) &&
             validOptionalString('releaseYear', 1, 10) &&
             validOptionalString('totalDuration', 1, 50) &&
             (!( 'isFeatured' in data) || data.isFeatured == null || data.isFeatured is bool) &&
             validOptionalString('genre', 1, 100) &&
             (!( 'rating' in data) || data.rating == null || (data.rating is number && data.rating >= 0 && data.rating <= 10)) &&
             validOptionalString('description', 1, 2000) &&
             validOptionalString('posterUrl', 1, 1000) &&
             validOptionalString('backdropUrl', 1, 1000);
    }

    match /movies/{document=**} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /movies/{movieId}/comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasRequiredFields(['text', 'userId', 'userName', 'createdAt']) && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /{path=**}/comments/{commentId} {
      allow read: if true;
    }

    match /ratings/{userId_movieId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasRequiredFields(['userId', 'movieId', 'rating', 'createdAt']) && request.resource.data.userId == request.auth.uid && userId_movieId == request.auth.uid + '_' + request.resource.data.movieId;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && request.resource.data.rating == request.resource.data.rating;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'name', 'email', 'createdAt']);
      allow update: if isOwner(userId) && uidNotModified();
    }
  }
}
